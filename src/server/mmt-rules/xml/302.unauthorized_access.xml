<beginning>
<!-- Property 302: request rejected by the server as unauthorized/forbidden. -->
<property value="THEN" delay_units="ms" delay_min="0" delay_max="0" property_id="302" type_property="ATTACK"
     description="Unauthorized/forbidden API access (rejected by server)">
   <event event_id="1" value="COMPUTE"
       description="Context: an HTTP response"
       boolean_expression="(http.response != '')"/>
   <event event_id="2" value="COMPUTE"
       description="Trigger: auth-failure status code"
       boolean_expression="((#strstr(http.response,'401')!=0) || (#strstr(http.response,'403')!=0))"/>
 </property>
</beginning>
